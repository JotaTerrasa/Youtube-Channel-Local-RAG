APP_DATA_DIR=./data

# Local services
WHISPER_URL=http://localhost:9000
CHROMA_HOST=localhost
CHROMA_PORT=8000
OLLAMA_BASE_URL=http://localhost:11434

# LLM already present in your Ollama install
OLLAMA_MODEL=gemma4:e2b

# RAG collection and retrieval
CHROMA_COLLECTION=youtube_knowledge
RETRIEVE_K=6

# Default embeddings are fully local, multilingual, and do not require another Ollama model.
# Optional Ollama embeddings:
#   ollama pull nomic-embed-text
#   EMBEDDING_PROVIDER=ollama
#   OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Chunking
CHUNK_MAX_SECONDS=120
CHUNK_OVERLAP_SECONDS=20
CHUNK_MAX_CHARS=2600

